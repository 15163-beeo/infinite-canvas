# 管理员账号，首次启动会自动创建。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=infinite-canvas

# JWT 登录密钥和过期时间，正式部署请修改 JWT_SECRET。
JWT_SECRET=infinite-canvas
JWT_EXPIRE_HOURS=168

# 后端监听端口
PORT=18080

# 前端开发代理默认使用 http://127.0.0.1:18080，如后端开发端口不同，启动前端时可单独设置 API_BASE_URL。
# API_BASE_URL=http://127.0.0.1:18080

# 数据库配置，默认使用本地 SQLite。
STORAGE_DRIVER=sqlite
# sqlite: DATABASE_DSN=data/infinite-canvas.db
# mysql: DATABASE_DSN=user:password@tcp(127.0.0.1:3306)/infinite_canvas?parseTime=true
# postgres: DATABASE_DSN=postgres://user:password@127.0.0.1:5432/infinite_canvas?sslmode=disable
DATABASE_DSN=data/infinite-canvas.db

# 去背景主路径：阿里云视觉智能开放平台 ImageSeg 商品分割（SegmentCommodity）。
# 配置 AK 后会优先使用该服务；未配置时自动回退到本地/GPT 去背景逻辑。
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_IMAGESEG_REGION=cn-shanghai
ALIYUN_IMAGESEG_ENDPOINT=imageseg.cn-shanghai.aliyuncs.com
ALIYUN_IMAGESEG_ENABLED=true
ALIYUN_IMAGESEG_TIMEOUT_SECONDS=20
ALIYUN_OCR_ENABLED=true
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com
ALIYUN_OCR_TYPE=Advanced
ALIYUN_OCR_TIMEOUT_SECONDS=20
ALIYUN_OCR_MIN_CONFIDENCE=55

# 阿里云百炼 DashScope（画布图片编辑文字 OCR）
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_OCR_MODEL=qwen-vl-ocr
